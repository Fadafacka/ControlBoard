Sub Button1_Click()

    Dim Data As Worksheet
    Set Data = Worksheets("Data")
    With Data
        .Cells.Value = Empty
        .[A1].Select
        .Paste
    End With
    Set Data = Nothing
    
    Dim Ov As Object
    Set Ov = Worksheets("Overview")
    Ov.Select
    set Ov = Nothing

End Sub
